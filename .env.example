# ===== App =====
PORT=3000
NODE_ENV=development
SERVICE_NAME=casecellshop-backend
LOG_LEVEL=info

# ===== Drivers (redis | memory) =====
# memory = roda sem Docker (default, usado nos testes)
# redis  = runtime de produção (docker-compose sobe o Redis)
CACHE_DRIVER=memory
QUEUE_DRIVER=memory
STOCK_DRIVER=memory
IDEMPOTENCY_DRIVER=memory

# ===== Redis (usado quando *_DRIVER=redis) =====
REDIS_URL=redis://localhost:6379

# ===== Cache =====
PRODUCTS_CACHE_TTL_MS=15000
CACHE_STAMPEDE_JITTER_MS=2000

# ===== Checkout / worker =====
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_MS=500
ERP_FAIL_RATE=0.3
ERP_MIN_LATENCY_MS=50
ERP_MAX_LATENCY_MS=300
RECONCILE_AGE_MS=10000
RECONCILE_MAX_AGE_MS=60000

# ===== Observabilidade (opcional) =====
# Se definido, traces são exportados via OTLP (compatível Datadog Agent). Caso contrário, console/no-op.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
